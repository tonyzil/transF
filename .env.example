# Copy to .env and fill in to switch the funding leg from mock to the real
# Monerium sandbox. Create an app (sandbox environment) at https://monerium.dev
# — Developers section — and paste its credentials here.
MONERIUM_CLIENT_ID=
MONERIUM_CLIENT_SECRET=

# Candide smart wallets (public Sepolia endpoints, no key needed)
# CANDIDE_CHAIN_ID=11155111
# CANDIDE_BUNDLER_URL=https://api.candide.dev/public/v3/11155111
# CANDIDE_PAYMASTER_URL=https://api.candide.dev/public/v3/11155111
# CANDIDE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Defaults (rarely need changing)
# MONERIUM_BASE_URL=https://api.monerium.dev
# MONERIUM_CHAIN=sepolia   # sandbox wants testnet names; production: ethereum/gnosis/polygon
# MONERIUM_PROFILE_ID=
# MONERIUM_POLL_MS=15000
# Shared secret for webhook deliveries, as shown by Monerium (`whsec_...`).
# The receiver verifies webhook-id.webhook-timestamp.rawBody against
# webhook-signature and then re-reads every order from Monerium.
# MONERIUM_WEBHOOK_SECRET=whsec_...
# TRANSF_RPC_URL=http://127.0.0.1:8545
# TRANSF_API_PORT=3000
# KYC_AUTO_APPROVE=0 # production/fail-closed mode; local demos auto-approve by default

# Cash-pickup anchor (SEP-10/SEP-24). Default empty = mock MoneyGram.
# Stellar's public test anchor works with no signup; production MoneyGram is
# their home domain + partner-onboarded account + MG_ANCHOR_ASSET=USDC.
# MG_ANCHOR_DOMAIN=testanchor.stellar.org
# MG_ANCHOR_ASSET=SRT
# Stellar network endpoints. Defaults are public testnet endpoints.
# STELLAR_HORIZON=https://horizon-testnet.stellar.org
# STELLAR_SOROBAN_RPC=https://soroban-testnet.stellar.org
# STELLAR_PASSPHRASE=Test SDF Network ; September 2015
# STELLAR_FRIENDBOT=https://friendbot.stellar.org
# Treasury signer used for SEP-10 auth, SEP-24 on-ledger payment, and Stellar
# CCTP mint submission. In production, use managed signing, not a plaintext env.
# STELLAR_TREASURY_SECRET=
# Production MoneyGram onboarding may require these SEP-10 values:
# MG_AUTH_MEMO=                 # positive integer user memo for custodial auth
# MG_CLIENT_DOMAIN=             # wallet/client domain, if MoneyGram requires it
# MG_CLIENT_DOMAIN_SIGNING_SECRET= # secret for that domain's SIGNING_KEY

# CCTP bridge (Base Sepolia -> Stellar testnet). Dry-run unless CCTP_LIVE=1.
# CCTP_LIVE=0
# CCTP_BASE_RPC=https://sepolia.base.org
# CCTP_BURNER_KEY=   # funded EOA: Base Sepolia ETH + USDC from faucet.circle.com
# CCTP_STELLAR_RECIPIENT= # optional; defaults to STELLAR_TREASURY_SECRET public key
# CCTP_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
# CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
# CCTP_STELLAR_FORWARDER=CA66Q2WFBND6V4UEB7RD4SAXSVIWMD6RA4X3U32ELVFGXV5PJK4T4VSZ
# CCTP_STELLAR_MSG_TRANSMITTER=CBJ6MTCKKZG73PMDZCJMSFRD7DQEMI4FKDH7CGDSV4W6FHCRBCQAVVJY
# CCTP_IRIS_BASE=https://iris-api-sandbox.circle.com
